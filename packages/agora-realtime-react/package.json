{
  "name": "agora-realtime-react",
  "version": "0.1.2",
  "description": "AI SDK-compatible React hooks and voice UI primitives for Agora WebRTC voice agents in Vercel and React apps.",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "agora",
    "realtime",
    "voice-ai",
    "voice-agent",
    "realtime-voice",
    "ai-agents",
    "ai-sdk",
    "vercel-ai-sdk",
    "useRealtime",
    "webrtc",
    "react",
    "hooks",
    "rtc",
    "convoai",
    "vercel"
  ],
  "homepage": "https://agora-realtime-agent.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgoraIO-Community/agora-realtime-agent.git",
    "directory": "packages/agora-realtime-react"
  },
  "bugs": {
    "url": "https://github.com/AgoraIO-Community/agora-realtime-agent/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@ai-sdk/react": "4.0.9",
    "agora-rtc-sdk-ng": "^4.24.5",
    "ai": "7.0.8",
    "react": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "4.0.9",
    "agora-rtc-sdk-ng": "^4.24.5",
    "ai": "7.0.8",
    "react": "19.2.7",
    "typescript": "5.9.3"
  }
}
